cat << 'EOF' > .gitignore
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environments
venv/
env/
ENV/
.env/
.venv/

# IDE / OS
.idea/
.vscode/
.DS_Store

# Project specific: Ignore all heavy datasets, checkpoints, and eval logs
data/
outputs/
wandb/

# Ignore wandb and other logs
*.log
EOF
